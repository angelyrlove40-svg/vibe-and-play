{
  "name": "vibemud",
  "version": "0.1.26",
  "description": "코딩 터미널 옆에서 로컬로 실행되는 방치형 MUD/RPG CLI",
  "homepage": "https://github.com/angelyrlove40-svg/vibe-and-play#readme",
  "bugs": {
    "url": "https://github.com/angelyrlove40-svg/vibe-and-play/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelyrlove40-svg/vibe-and-play.git",
    "directory": "npm"
  },
  "bin": {
    "vibemud": "bin/vibemud.js",
    "mudctl": "bin/mudctl.js",
    "vibemud-runtime": "bin/vibemud-runtime.js",
    "vibemud-hud": "bin/vibemud-hud.js"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test:resolve": "node --test test/resolve.test.js",
    "pack:dry-run": "npm pack --dry-run --json",
    "check:pack-contents": "node scripts/check-pack-contents.js",
    "collect:artifacts": "node scripts/collect-native-artifacts.js",
    "verify:checksums": "node scripts/verify-native-checksums.js"
  },
  "optionalDependencies": {
    "@vibemud/native-darwin-arm64": "0.1.26",
    "@vibemud/native-darwin-x64": "0.1.26",
    "@vibemud/native-linux-arm64-gnu": "0.1.26",
    "@vibemud/native-linux-x64-gnu": "0.1.26",
    "@vibemud/native-win32-arm64-msvc": "0.1.26",
    "@vibemud/native-win32-x64-msvc": "0.1.26"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "files": [
    "bin",
    "scripts",
    "native",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "optionalDependenciesNote": "Published releases provide @vibemud/native-* optional packages; local repo installs may build from Cargo sources."
}
